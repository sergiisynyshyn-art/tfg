<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MeditationActivity">

    <!-- Fondo: Imagen con overlay oscuro -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/background_image"
        android:scaleType="centerCrop"
        android:src="@drawable/mount" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000" />

    <!-- ScrollView con contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="60dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <ImageButton
                android:id="@+id/btnBackMeditation"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/app_back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <ImageView
            android:id="@+id/imgMeditationFull"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meditation_image_placeholder"
            android:contentDescription="@string/meditation_image_desc" />

        <TextView
            android:id="@+id/tvMeditationFullTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/meditation_screen_title"
            android:textSize="28sp"
            android:fontFamily="@font/quattrocentobold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvMeditationFullDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/meditation_screen_duration"
            android:textSize="14sp"
            android:fontFamily="@font/quattrocentoregular"
            android:textColor="@color/white_translucent" />

        <TextView
            android:id="@+id/tvMeditationFullDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/meditation_screen_description"
            android:textSize="14sp"
            android:fontFamily="@font/quattrocentoregular"
            android:textColor="@color/white_translucent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:backgroundTint="@color/primary"
                android:padding="12dp"
                android:src="@drawable/ic_play_white"
                android:contentDescription="@string/play_meditation_desc" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <SeekBar
                    android:id="@+id/seekBarMeditation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvElapsed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/meditation_time_default"
                        android:textSize="12sp"
                        android:fontFamily="@font/quattrocentoregular"
                        android:textColor="@color/white_translucent" />

                    <TextView
                        android:id="@+id/tvTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/meditation_time_default"
                        android:textSize="12sp"
                        android:fontFamily="@font/quattrocentoregular"
                        android:textColor="@color/white_translucent" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>

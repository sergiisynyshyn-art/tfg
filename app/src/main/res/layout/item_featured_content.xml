<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardFeaturedContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen -->
        <ImageView
            android:id="@+id/imgFeaturedContent"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:contentDescription="@string/routine_image_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/meditation_image_placeholder" />

        <!-- Contenido de texto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Subtítulo pequeño -->
            <TextView
                android:id="@+id/tvFeaturedSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_soft"
                android:fontFamily="@font/quattrocentobold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Paisaje sonoro del día"
                android:textColor="@color/primary_dark"
                android:textSize="12sp" />

            <!-- Título principal -->
            <TextView
                android:id="@+id/tvFeaturedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/quattrocentobold"
                android:text="Montañas al amanecer"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvFeaturedDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/quattrocentoregular"
                android:text="Siente la brisa fría y el despertar de la naturaleza."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RoutinePlayerActivity">

    <!-- Fondo -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/background_image"
        android:scaleType="centerCrop"
        android:src="@drawable/mount" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000" />

    <!-- Contenedor principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header con botón atrás y número de paso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingTop="40dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBackRoutinePlayer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/routines_back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvStepNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/quattrocentoregular"
                android:text="@string/routine_step_placeholder"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Barra de progreso -->
        <ProgressBar
            android:id="@+id/progressBarRoutine"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="20dp"
            android:progress="0"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:indeterminate="false" />

        <!-- Imagen del paso -->
        <ImageView
            android:id="@+id/imgRoutineStep"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:contentDescription="@string/routine_image_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/meditation_image_placeholder"
            android:layout_marginBottom="20dp" />

        <!-- Scroll container para el contenido -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Título del paso -->
                <TextView
                    android:id="@+id/tvRoutineStepTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/quattrocentobold"
                    android:text="@string/routine_step_title_placeholder"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <!-- Contenedor para reproductor de audio -->
                <FrameLayout
                    android:id="@+id/playerContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- SeekBar -->
                        <SeekBar
                            android:id="@+id/seekBarRoutine"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:progress="0" />

                        <!-- Tiempo actual y total -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tvRoutineElapsed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quattrocentoregular"
                                android:text="0:00"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/tvRoutineTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/quattrocentoregular"
                                android:text="0:00"
                                android:textColor="@color/white_translucent"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Botón play/pause -->
                        <ImageButton
                            android:id="@+id/btnPlayPauseRoutine"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@drawable/button_play_pause_background"
                            android:contentDescription="@string/play_meditation_desc"
                            android:padding="12dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_play_white"
                            app:tint="@color/white" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Contenedor para texto -->
                <FrameLayout
                    android:id="@+id/textContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvRoutineStepContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quattrocentoregular"
                            android:text="@string/routine_content_placeholder"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:lineSpacingMultiplier="1.5"
                            android:gravity="center" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Contenedor completado -->
                <FrameLayout
                    android:id="@+id/completionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quattrocentobold"
                            android:text="@string/routine_completed_title"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/quattrocentoregular"
                            android:text="@string/routine_completed_message"
                            android:textColor="@color/white_translucent"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Botones de acción (continuar y finalizar) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRoutineContinue"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="@string/routines_continue"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:visibility="gone"
                app:backgroundTint="@color/primary"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinishRoutine"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="@string/routines_finish"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:visibility="gone"
                app:backgroundTint="@color/primary"
                app:cornerRadius="24dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>






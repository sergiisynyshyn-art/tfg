<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".InitialSurveyActivity">

    <!-- Imagen de fondo montaña -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/mount"
        android:scaleType="centerCrop"
        android:contentDescription="Background image" />

    <!-- Overlay oscuro para contraste -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0.5" />

    <!-- Contenido principal -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="60dp">

    <ImageButton
        android:id="@+id/btnBackSurvey"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/app_back"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <View
        android:id="@+id/blobTopLeft"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginStart="-40dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/survey_blob_cream"
        android:alpha="0.75"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/blobTopRight"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginEnd="-20dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/survey_blob_peach"
        android:alpha="0.7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/blobBottomLeft"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginStart="-56dp"
        android:layout_marginBottom="-50dp"
        android:background="@drawable/survey_blob_sky"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/logoCard"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/background_white"
        app:cardCornerRadius="70dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/yinyangphilosophy" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="12dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/survey_badge_bg"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/survey_badge"
                android:textColor="@color/primary_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/quattrocentobold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/survey_title"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:lineSpacingExtra="2dp"
                android:fontFamily="@font/quattrocentobold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/survey_subtitle"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="@font/quattrocentoregular" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="@string/survey_question"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/quattrocentobold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWellbeing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/survey_card_default"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#12A3A9B7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/survey_badge_bg"
                        android:gravity="center"
                        android:text="@string/survey_icon_wellbeing"
                        android:textColor="@color/primary_dark"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/survey_goal_wellbeing"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/quattrocentobold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/survey_card_default"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#12A3A9B7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/survey_badge_bg"
                        android:gravity="center"
                        android:text="@string/survey_icon_stress"
                        android:textColor="@color/primary_dark"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/survey_goal_stress"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/quattrocentobold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/survey_card_default"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#12A3A9B7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/survey_badge_bg"
                        android:gravity="center"
                        android:text="@string/survey_icon_sleep"
                        android:textColor="@color/primary_dark"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/survey_goal_sleep"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/quattrocentobold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/survey_card_default"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#12A3A9B7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/survey_badge_bg"
                        android:gravity="center"
                        android:text="@string/survey_icon_balance"
                        android:textColor="@color/primary_dark"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/survey_goal_balance"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/quattrocentobold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFocus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/survey_card_default"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#12A3A9B7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/survey_badge_bg"
                        android:gravity="center"
                        android:text="@string/survey_icon_focus"
                        android:textColor="@color/primary_dark"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:text="@string/survey_goal_focus"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="@font/quattrocentobold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSurveyContinue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:enabled="false"
                android:text="@string/survey_continue"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="@font/quattrocentobold"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/primary"
                />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>


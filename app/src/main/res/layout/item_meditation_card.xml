<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="220dp"
    android:layout_height="140dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#33FFFFFF">

    <!-- Contenedor principal: imagen de fondo + contenidos encima -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Imagen o ilustración suave relacionada con la meditación -->
        <ImageView
            android:id="@+id/imgMeditation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/meditation_image_placeholder"
            android:contentDescription="@string/meditation_image_desc"
            tools:ignore="ContentDescription" />

        <!-- Overlay sutil para mejorar legibilidad del texto -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <!-- Texto y metadatos (alineados abajo a la izquierda) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:gravity="bottom"
            android:layout_gravity="bottom">

            <TextView
                android:id="@+id/tvMeditationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/meditation_title"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/quattrocentobold"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tvMeditationDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meditation_duration"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/quattrocentoregular" />

            <TextView
                android:id="@+id/tvMeditationDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/meditation_description"
                android:textColor="#DDFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/quattrocentoregular"
                android:ellipsize="end"
                android:maxLines="2" />

        </LinearLayout>

        <!-- Botón de reproducir: preparado para integrarse con MediaPlayer
             Se puede enlazar con un onClick que llame a playMeditation(R.raw.respiracion_consciente)
             y/o leer el tag: @raw/respiracion_consciente -->
        <ImageButton
            android:id="@+id/btnPlayMeditation"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:backgroundTint="#66FFFFFF"
            android:padding="8dp"
            android:scaleType="center"
            android:src="@drawable/ic_play_white"
            android:contentDescription="@string/play_meditation_desc"
            android:tag="@raw/medit1"
            android:onClick="playMeditation" />

    </FrameLayout>

</androidx.cardview.widget.CardView>



